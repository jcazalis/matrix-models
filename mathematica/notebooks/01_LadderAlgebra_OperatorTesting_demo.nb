Cell["2. Basic Operator Algebra", "Section",
 CellChangeTimes->{{3.9, 
  3.9}},ExpressionUUID->"b8d81e2c-e0f7-4576-8148-4707ec951d34"],

Cell[CellGroupData[{

Cell["2.1 Ladder Operators with Explicit Indices", "Subsection",
 CellChangeTimes->{{3.9, 3.9}, {3.972461788568719*^9, 
  3.972461814039164*^9}},ExpressionUUID->"21dc55d9-b16c-4655-8eee-\
9f6822dab97b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"expr1", "=", 
   RowBox[{
    RowBox[{"ad", "[", 
     RowBox[{"1", ",", "2"}], "]"}], "**", 
    RowBox[{"a", "[", 
     RowBox[{"2", ",", "1"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Original expression: \>\"", ",", 
   RowBox[{"TraditionalForm", "[", "expr1", "]"}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"simplified1", "=", 
   RowBox[{"SimplifyNC", "[", "expr1", "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<After applying commutation relations: \>\"", ",", 
   RowBox[{"TraditionalForm", "[", "simplified1", "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9, 3.9}, {3.972461601054838*^9, 3.972461623237844*^9}, {
