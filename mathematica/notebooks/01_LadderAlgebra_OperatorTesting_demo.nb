Cell[CellGroupData[{

Cell["3.4 Twisted trace operators", "Subsection",
 CellChangeTimes->{{3.972464845518601*^9, 
  3.972464853242969*^9}},ExpressionUUID->"8727b439-3bf3-4b2d-be18-\
9f621e0935a3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"X", "[", 
    RowBox[{"k_", ",", "l_"}], "]"}], ":=", 
   RowBox[{"QuadratureX", "[", 
    RowBox[{"k", ",", "l", ",", "1"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Sigma]1", "=", 
   RowBox[{"Cycles", "[", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Sigma]2", "=", 
   RowBox[{"Cycles", "[", 
    RowBox[{"{", 
     RowBox[{"{", "}"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tr1", "=", 
   RowBox[{
    RowBox[{"trSigma", "[", 
     RowBox[{"\[Sigma]1", ",", "X", ",", "X"}], "]"}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tr2", "=", 
   RowBox[{
    RowBox[{"trSigma", "[", 
     RowBox[{"\[Sigma]2", ",", "X", ",", "X"}], "]"}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Tr(X^2) = \>\"", ",", " ", 
   RowBox[{"tr1", "//", "TraditionalForm"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Tr(X)^2 = \>\"", ",", " ", 
   RowBox[{"tr2", "//", "TraditionalForm"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.972464867862992*^9, 3.972465003631299*^9}},
 CellLabel->"In[32]:=",ExpressionUUID->"2a5ea01e-7cad-4f12-86f5-0382fd9904af"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Tr(X^2) = \"\>", "\[InvisibleSpace]", 
   TagBox[
    FormBox[
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         FormBox[
          TemplateBox[{"a", "k1", "k2"},
           "Subsuperscript"],
          TraditionalForm], "**", 
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k1", "k2"},
           "Subsuperscript"],
          TraditionalForm]}], "+", 
        RowBox[{
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k1", "k2"},
           "Subsuperscript"],
          TraditionalForm], "**", 
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k2", "k1"},
           "Subsuperscript"],
          TraditionalForm]}], "+", 
        RowBox[{
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k2", "k1"},
           "Subsuperscript"],
          TraditionalForm], "**", 
         FormBox[
          TemplateBox[{"a", "k2", "k1"},
           "Subsuperscript"],
          TraditionalForm]}], "+", 
        RowBox[{
         FormBox[
          TemplateBox[{"a", "k1", "k2"},
           "Subsuperscript"],
          TraditionalForm], "**", 
         FormBox[
          TemplateBox[{"a", "k2", "k1"},
           "Subsuperscript"],
          TraditionalForm]}]}], ")"}]}],
     TraditionalForm],
    TraditionalForm,
    Editable->True]}],
  SequenceForm["Tr(X^2) = ", 
