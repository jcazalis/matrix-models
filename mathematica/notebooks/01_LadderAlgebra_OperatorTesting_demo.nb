         "Subsuperscript"],
        TraditionalForm]}]}],
     TraditionalForm],
    TraditionalForm,
    Editable->True]}],
  SequenceForm["Simplified (symbolic): ", 
   TraditionalForm[NonCommutativeMultiply[
      LadderAlgebra`a[$CellContext`l2, $CellContext`l1], 
      LadderAlgebra`ad[$CellContext`k1, $CellContext`k2]] - 
    LadderAlgebra`\[Delta][$CellContext`k1, $CellContext`l1] 
    LadderAlgebra`\[Delta][$CellContext`l2, $CellContext`k2]]],
  Editable->False]], "Print",
 CellChangeTimes->{3.9724615913976517`*^9, 3.972461638387755*^9, 
  3.972461689337011*^9, 3.97506033410374*^9, 3.975060374058865*^9, 
