         LadderAlgebra`ad[2, 1], 
         LadderAlgebra`a[1, 1]] + NonCommutativeMultiply[
         LadderAlgebra`ad[2, 2], 
         LadderAlgebra`a[2, 1]], NonCommutativeMultiply[
         LadderAlgebra`ad[2, 1], 
