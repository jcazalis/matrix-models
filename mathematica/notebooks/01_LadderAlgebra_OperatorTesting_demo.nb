Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Symbolic expression: \"\>", "\[InvisibleSpace]", 
   TagBox[
    FormBox[
     RowBox[{
      FormBox[
       TemplateBox[{
         SuperscriptBox["a", "\[Dagger]"], "k1", "k2"},
        "Subsuperscript"],
       TraditionalForm], "**", 
      FormBox[
       TemplateBox[{"a", "l2", "l1"},
        "Subsuperscript"],
       TraditionalForm]}],
     TraditionalForm],
    TraditionalForm,
    Editable->True]}],
  SequenceForm["Symbolic expression: ", 
   TraditionalForm[
    NonCommutativeMultiply[
     LadderAlgebra`ad[$CellContext`k1, $CellContext`k2], 
