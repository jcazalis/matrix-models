 CellChangeTimes->{{3.9, 
  3.9}},ExpressionUUID->"d6690c97-f6a2-472c-b8e5-6fc78616364d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"exprEinstein", "=", 
   RowBox[{
    RowBox[{"ad", "[", 
     RowBox[{"k1", ",", "k2"}], "]"}], "**", 
    RowBox[{"a", "[", 
     RowBox[{"k2", ",", "k1"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Einstein notation expression: \>\"", ",", 
   RowBox[{"exprEinstein", "//", "TraditionalForm"}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"expanded", "=", 
   RowBox[{"ExpandImplicitIndices", "[", 
    RowBox[{"exprEinstein", ",", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Expanded for dim=2: \>\"", ",", 
   RowBox[{"expanded", "//", "TraditionalForm"}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"simplifiedExpanded", "=", 
   RowBox[{"SimplifyNC", "[", "expanded", "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Simplified: \>\"", ",", 
   RowBox[{"simplifiedExpanded", "//", "TraditionalForm"}]}], "]"}]}], "Input",\

