Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Einstein notation expression: \"\>", "\[InvisibleSpace]", 
   TagBox[
    FormBox[
     RowBox[{
      FormBox[
       TemplateBox[{
         SuperscriptBox["a", "\[Dagger]"], "k1", "k2"},
