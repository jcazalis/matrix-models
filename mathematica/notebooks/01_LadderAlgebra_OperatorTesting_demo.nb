    RowBox[{"ad", "[", 
     RowBox[{"k1", ",", "k2"}], "]"}], "**", 
    RowBox[{"a", "[", 
     RowBox[{"k2", ",", "k1"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rhs2", "=", 
