      RowBox[{"k2", ",", "k1"}], "]"}], "**", 
     RowBox[{"ad", "[", 
      RowBox[{"k1", ",", "k2"}], "]"}]}], "-", 
    RowBox[{
     RowBox[{"\[Delta]", "[", 
      RowBox[{"k1", ",", "k1"}], "]"}], "*", 
     RowBox[{"\[Delta]", "[", 
      RowBox[{"k2", ",", "k2"}], "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dimMax", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"TestOperatorEquality", "[", 
