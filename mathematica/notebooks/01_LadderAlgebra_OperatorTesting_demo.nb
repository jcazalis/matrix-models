Cell[CellGroupData[{

Cell["5.3 Trace of Matrix Operators", "Subsection",
 CellChangeTimes->{{3.9, 
  3.9}},ExpressionUUID->"b2a7c3d8-f1df-417d-bc4b-46d4115569c1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"traceResult", "=", 
   RowBox[{"NCTr", "[", "product", "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Tr(A\[Dagger] * A) = \>\"", ",", 
   RowBox[{"traceResult", "//", "TraditionalForm"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", 
