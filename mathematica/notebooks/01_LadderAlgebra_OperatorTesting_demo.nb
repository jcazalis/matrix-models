          SuperscriptBox["a", "\[Dagger]"], "1", "1"},
         "Subsuperscript"],
        TraditionalForm], "**", 
       FormBox[
        TemplateBox[{"a", "1", "1"},
         "Subsuperscript"],
        TraditionalForm]}], "+", 
