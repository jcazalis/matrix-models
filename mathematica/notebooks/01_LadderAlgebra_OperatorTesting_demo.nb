 InterpretationBox[
  RowBox[{"\<\"Tr(A\[Dagger] * A) = \"\>", "\[InvisibleSpace]", 
   TagBox[
    FormBox[
     RowBox[{
      RowBox[{
       FormBox[
        TemplateBox[{
          SuperscriptBox["a", "\[Dagger]"], "1", "1"},
         "Subsuperscript"],
        TraditionalForm], "**", 
