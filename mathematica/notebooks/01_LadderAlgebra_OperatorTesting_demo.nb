Cell[TextData[{
 "Notice that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Delta]", "[", 
    RowBox[{"k1", ",", "k1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "c5bc2799-9236-4890-bc0b-7207c0ec6cd3"],
 " remains unevaluated for symbolic indices, unlike KroneckerDelta which \
would incorrectly evaluate to 1."
}], "Text",
