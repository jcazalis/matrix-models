Cell[CellGroupData[{

Cell["1.1 Define a cyclic product", "Subsection",
 CellChangeTimes->{{3.9810873528019943`*^9, 
  3.981087365221373*^9}},ExpressionUUID->"82f13611-9fef-4be4-9b75-\
80bab49377c4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Quadrature", " ", "operator", " ", "X"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"a", " ", "+", " ", "a\[Dagger]"}], ")"}], "/", 
     RowBox[{"\[Sqrt]", 
      RowBox[{"(", 
       RowBox[{"2", "m"}], ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"K", "=", "4"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Tr(X^4) = \>\"", ",", " ", 
     RowBox[{
      RowBox[{"CyclicProduct", "[", 
       RowBox[{"K", ",", " ", "m"}], "]"}], "//", "TraditionalForm"}]}], " ", 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.981087380929305*^9, 3.981087543489172*^9}, {
  3.981087655441059*^9, 3.981087655768796*^9}, {3.981595902304731*^9, 
  3.981595909040984*^9}, {3.9815960084372463`*^9, 3.98159601999855*^9}, {
  3.9815961585862827`*^9, 3.981596167146882*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"c04cad66-25e3-4a71-8fdf-44c56a3ca239"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Tr(X^4) = \"\>", "\[InvisibleSpace]", 
   TagBox[
    FormBox[
     RowBox[{
      FractionBox["1", "4"], " ", 
      RowBox[{
       FractionBox[
        RowBox[{
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k1", "k2"},
           "Subsuperscript"],
          TraditionalForm], "+", 
         FormBox[
          TemplateBox[{"a", "k1", "k2"},
           "Subsuperscript"],
          TraditionalForm]}], 
        SqrtBox["m"]], "**", 
       FractionBox[
        RowBox[{
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k2", "k3"},
           "Subsuperscript"],
          TraditionalForm], "+", 
         FormBox[
          TemplateBox[{"a", "k2", "k3"},
           "Subsuperscript"],
          TraditionalForm]}], 
        SqrtBox["m"]], "**", 
       FractionBox[
        RowBox[{
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k3", "k4"},
           "Subsuperscript"],
          TraditionalForm], "+", 
         FormBox[
          TemplateBox[{"a", "k3", "k4"},
           "Subsuperscript"],
          TraditionalForm]}], 
        SqrtBox["m"]], "**", 
       FractionBox[
        RowBox[{
         FormBox[
          TemplateBox[{
            SuperscriptBox["a", "\[Dagger]"], "k4", "k1"},
           "Subsuperscript"],
          TraditionalForm], "+", 
         FormBox[
          TemplateBox[{"a", "k4", "k1"},
           "Subsuperscript"],
          TraditionalForm]}], 
        SqrtBox["m"]]}]}],
     TraditionalForm],
    TraditionalForm,
    Editable->True]}],
  SequenceForm["Tr(X^4) = ", 
   TraditionalForm[
   Rational[1, 4] 
    NonCommutativeMultiply[$CellContext`m^Rational[-1, 2] (
       LadderAlgebra`a[$CellContext`k1, $CellContext`k2] + 
       LadderAlgebra`ad[$CellContext`k1, $CellContext`k2]), $CellContext`m^
       Rational[-1, 2] (LadderAlgebra`a[$CellContext`k2, $CellContext`k3] + 
       LadderAlgebra`ad[$CellContext`k2, $CellContext`k3]), $CellContext`m^
       Rational[-1, 2] (LadderAlgebra`a[$CellContext`k3, $CellContext`k4] + 
       LadderAlgebra`ad[$CellContext`k3, $CellContext`k4]), $CellContext`m^
       Rational[-1, 2] (LadderAlgebra`a[$CellContext`k4, $CellContext`k1] + 
       LadderAlgebra`ad[$CellContext`k4, $CellContext`k1])]]],
  Editable->False]], "Print",
 CellChangeTimes->{3.981596167536337*^9},
 CellLabel->
  "During evaluation of \
