        RowBox[{"cachedGroundState", "[", 
         RowBox[{"g", ",", "dim"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Create", " ", "labels", " ", "from", " ", "RList"}], "-", 
         RowBox[{"match", " ", "the", " ", "basis", " ", "order"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"labels", "=", 
        RowBox[{"ToString", "/@", 
         RowBox[{"RListGS", "[", 
          RowBox[{"[", "filter", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
        "\[IndentingNewLine]", 
       RowBox[{"(*", 
