  RowBox[{
   RowBox[{"RListGS", " ", "=", " ", 
    RowBox[{"Select", "[", 
     RowBox[{"RList", ",", " ", 
      RowBox[{
       RowBox[{"EvenQ", "[", 
        RowBox[{"Total", "[", "#", "]"}], "]"}], " ", "&"}]}], "]"}]}], ";"}],
