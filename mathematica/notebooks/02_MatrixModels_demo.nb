Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Find", " ", "positions", " ", "of", " ", "all", " ", "states", " ", 
    "with", " ", "at", " ", "most", " ", "dim", " ", "rows"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"filteredStatePositionsGS", "[", "dim_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Position", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"#", "<=", "dim"}], "&"}], "/@", 
         RowBox[{"Length", "/@", "RListGS"}]}], ",", "True"}], "]"}], "//", 
      "Flatten"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Create", " ", "memoization", " ", "for", " ", "the", " ", "eigensystem", 
     " ", "computation"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "cachedGroundState", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"cachedGroundState", "[", 
      RowBox[{"g_", ",", "dim_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"cachedGroundState", "[", 
       RowBox[{"g", ",", "dim"}], "]"}], "=", "\[IndentingNewLine]", 
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"H", ",", "filter", ",", "ES", ",", "e", ",", "\[Psi]"}], 
         "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"H", "=", 
          RowBox[{
           RowBox[{"2", " ", "Hfree"}], "+", 
           RowBox[{"g", " ", 
            RowBox[{"Hint", "/", "d"}]}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"filter", "=", 
          RowBox[{"filteredStatePositionsGS", "[", "dim", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"H", "=", 
          RowBox[{"H", "[", 
           RowBox[{"[", 
            RowBox[{"filter", ",", "filter"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"H", "=", 
          RowBox[{
           RowBox[{"H", " ", "/.", 
            RowBox[{"d", "->", "dim"}]}], "//", "N"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"ES", "=", 
          RowBox[{"Eigensystem", "[", 
           RowBox[{"H", ",", 
            RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"e", "=", 
          RowBox[{"ES", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"\[Psi]", "=", 
          RowBox[{
           RowBox[{"ES", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"e", ",", "\[Psi]"}], "}"}]}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Parallel", " ", "precomputation", " ", "of", " ", "GS"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DistributeDefinitions", "[", 
     RowBox[{
     "Hfree", ",", "Hint", ",", "d", ",", "RListGS", ",", 
      "filteredStatePositionsGS", ",", "cachedGroundState"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"ParallelDo", "[", 
    RowBox[{
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"cachedGroundState", "[", 
        RowBox[{"g", ",", "dim"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"g", ",", 
         RowBox[{"Range", "[", 
          RowBox[{"0", ",", "4.0", ",", "0.05"}], "]"}]}], "}"}]}], "]"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"dim", ",", "2", ",", "maxDim"}], "}"}], ",", 
     RowBox[{"ProgressReporting", "->", "True"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.97988168022284*^9, 3.9798816806311417`*^9}, {
