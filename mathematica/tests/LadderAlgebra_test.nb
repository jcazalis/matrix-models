Cell[CellGroupData[{

Cell["Adjoint Consistency", "Subsection",
 CellChangeTimes->{3.972374331005327*^9},
 CellID->445279424,ExpressionUUID->"e8134400-499f-49c2-849e-3aa0e46a7393"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"psi", " ", "=", " ", 
   RowBox[{"I", " ", 
    RowBox[{"Ket", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], "]"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"phi", " ", "=", " ", 
   RowBox[{"4", 
    RowBox[{"Ket", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], "]"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"braket1", " ", "=", " ", 
   RowBox[{
    RowBox[{"Adjoint", "[", "psi", "]"}], " ", "**", " ", 
    RowBox[{"a", "[", 
     RowBox[{"1", ",", " ", "1"}], "]"}], " ", "**", " ", "phi"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"braket2", " ", "=", " ", 
   RowBox[{
    RowBox[{"Adjoint", "[", "phi", "]"}], " ", "**", " ", 
    RowBox[{"ad", "[", 
     RowBox[{"1", ",", " ", "1"}], "]"}], " ", "**", " ", "psi"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"braket1", "==", 
  RowBox[{"Conjugate", "[", "braket2", "]"}]}]}], "VerificationTest",
 CellChangeTimes->{{3.972374167380126*^9, 3.972374271742344*^9}, {
  3.972374315781492*^9, 3.97237432100243*^9}},
 CellLabel->"In[33]:=",
 CellID->459629158,ExpressionUUID->"249503d3-a135-4d46-a4da-5c252d7576aa"],

