Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"m", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{"TotalHarmonicOscillator", "[", 
    RowBox[{"2", ",", "2", ",", "m"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"X", "=", 
   RowBox[{"MatrixX", "[", 
    RowBox[{"2", ",", "2", ",", "m"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P", "=", 
   RowBox[{"MatrixP", "[", 
    RowBox[{"2", ",", "2", ",", "m"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lhs", "=", 
   RowBox[{
    RowBox[{"NCTr", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"m", "^", "2"}], "*", 
       RowBox[{"NCMatrixPower", "[", 
        RowBox[{"X", ",", "2"}], "]"}]}], "+", 
      RowBox[{"NCMatrixPower", "[", 
       RowBox[{"P", ",", "2"}], "]"}]}], "]"}], "/", "2"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rhs", "=", "H"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lhs", "-", "rhs"}], "//", "SimplifyNC"}]}], "VerificationTest",
 CellChangeTimes->{{3.9723830106235447`*^9, 3.972383033618425*^9}},
 CellLabel->"In[36]:=",
 CellID->808018799,ExpressionUUID->"4fd50f7d-a72d-4b02-8114-5c11d56de255"],

