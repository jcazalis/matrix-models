Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ket1", " ", "=", " ", 
   RowBox[{"Ket", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"bra1", " ", "=", " ", 
   RowBox[{"Bra", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "0"}], "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"inner1", " ", "=", " ", 
  RowBox[{"bra1", " ", "**", " ", "ket1"}]}]}], "VerificationTest",
 CellChangeTimes->{{3.972373937348796*^9, 3.972373938623451*^9}},
 CellLabel->"In[26]:=",
