Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"testKet", " ", "=", " ", 
   RowBox[{"Ket", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "2"}], "}"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"testKetToBra", " ", "=", " ", 
   RowBox[{"Adjoint", "[", "testKet", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"testKetToBraToKet", " ", "=", " ", 
   RowBox[{"Adjoint", "[", "testKetToBra", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"testKet", "==", "testKetToBraToKet"}]}], "VerificationTest",
