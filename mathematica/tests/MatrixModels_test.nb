Cell[BoxData[{
 RowBox[{
  RowBox[{"RList", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", "}"}], ",", 
     RowBox[{"{", "1", "}"}], ",", 
     RowBox[{"{", "2", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RSList", "=", 
   RowBox[{"Tuples", "[", 
    RowBox[{"RList", ",", "2"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ops", "=", "\"\<XX\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"perm", "=", 
   RowBox[{"{", 
    RowBox[{"2", ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dim", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lhs", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"QuietEcho", "@", 
      RowBox[{"ComputeBruteForce", "[", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], ",", "ops", ",", "perm", ",", 
        "dim"}], "]"}]}], "&"}], "/@", "RSList"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rhs", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"QuietEcho", "@", 
       RowBox[{"ComputeMatrixElementInteraction", "[", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", "ops", ",", " ", "perm", ",", 
         RowBox[{"UseWovenContractions", "->", "False"}]}], "]"}]}], "&"}], "/@",
      "RSList"}], "/.", 
    RowBox[{"d", "->", "dim"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"lhs", "==", "rhs"}]}], "VerificationTest",
