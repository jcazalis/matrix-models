 RowBox[{
  RowBox[{"S", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ops", "=", "\"\<XX\>\""}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"perm", "=", 
   RowBox[{"{", 
    RowBox[{"2", ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dim", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lhs", " ", "=", " ", 
   RowBox[{"ComputeBruteForce", "[", 
    RowBox[{"R", ",", "S", ",", "ops", ",", " ", "perm", ",", "dim"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rhs", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"ComputeMatrixElementInteraction", "[", 
      RowBox[{"R", ",", "S", ",", "ops", ",", " ", "perm", ",", " ", 
       RowBox[{"UseWovenContractions", "->", "False"}]}], "]"}], "/.", 
     RowBox[{"d", "->", "dim"}]}], "//", "QuietEcho"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"rhs", "==", "lhs"}]}], "VerificationTest",
