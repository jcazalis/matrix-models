Cell[CellGroupData[{

Cell["Test TestOperatorEqualityExplicit - Basic Identities", "Subsection",
 CellID->1544332147,ExpressionUUID->"08dbd114-90a5-4245-bc3c-1f1c0ac6ae15"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TestOperatorEqualityExplicit", "[", "\n", "    ", 
  RowBox[{
   RowBox[{
    RowBox[{"ad", "[", 
     RowBox[{"1", ",", " ", "2"}], "]"}], " ", "**", " ", 
    RowBox[{"a", "[", 
     RowBox[{"2", ",", " ", "1"}], "]"}]}], ",", "\n", "    ", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", 
      RowBox[{"2", ",", " ", "1"}], "]"}], " ", "**", " ", 
     RowBox[{"ad", "[", 
      RowBox[{"1", ",", " ", "2"}], "]"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"\[Delta]", "[", 
      RowBox[{"1", ",", " ", "1"}], "]"}], " ", "*", " ", 
     RowBox[{"\[Delta]", "[", 
      RowBox[{"2", ",", " ", "2"}], "]"}]}]}]}], "\n", "  ", 
  "]"}]], "VerificationTest",
 CellChangeTimes->{
  3.972448296517411*^9, {3.972452066737346*^9, 3.97245206856118*^9}},
 CellLabel->"In[18]:=",
 CellID->2031787426,ExpressionUUID->"70f0e5c5-9c91-42f4-ac3b-197d2d1de1f3"],

