Cell[BoxData[
 RowBox[{"TestOperatorEquality", "[", "\n", "    ", 
  RowBox[{
   RowBox[{
    RowBox[{"ad", "[", 
     RowBox[{"k1", ",", " ", "k2"}], "]"}], " ", "**", " ", 
    RowBox[{"a", "[", 
     RowBox[{"k2", ",", " ", "k1"}], "]"}]}], ",", "\n", "    ", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", 
      RowBox[{"k2", ",", " ", "k1"}], "]"}], " ", "**", " ", 
     RowBox[{"ad", "[", 
      RowBox[{"k1", ",", " ", "k2"}], "]"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"\[Delta]", "[", 
      RowBox[{"k1", ",", " ", "k1"}], "]"}], " ", "*", " ", 
     RowBox[{"\[Delta]", "[", 
      RowBox[{"k2", ",", " ", "k2"}], "]"}]}]}], ",", "\n", "    ", "3"}], 
  "\n", "  ", "]"}]], "VerificationTest",
 CellChangeTimes->{
  3.972448501018982*^9, {3.97245204236194*^9, 3.972452045899591*^9}},
 CellLabel->"In[28]:=",
 CellID->673149261,ExpressionUUID->"9afdfea5-52ad-428f-9d1e-c0e8cfc069ad"],

