Cell[CellGroupData[{

Cell["Test Matrix Operator Identities", "Subsection",
 CellID->959468191,ExpressionUUID->"7c42f065-49f0-4835-ab40-7375dcd96f99"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"A", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"1", ",", " ", "1"}], "]"}], ",", " ", 
       RowBox[{"a", "[", 
        RowBox[{"1", ",", " ", "2"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"2", ",", " ", "1"}], "]"}], ",", " ", 
       RowBox[{"a", "[", 
        RowBox[{"2", ",", " ", "2"}], "]"}]}], "}"}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"B", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ad", "[", 
        RowBox[{"1", ",", " ", "1"}], "]"}], ",", " ", 
       RowBox[{"ad", "[", 
        RowBox[{"1", ",", " ", "2"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ad", "[", 
        RowBox[{"2", ",", " ", "1"}], "]"}], ",", " ", 
       RowBox[{"ad", "[", 
        RowBox[{"2", ",", " ", "2"}], "]"}]}], "}"}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"result", " ", "=", " ", 
   RowBox[{"NCMatrixMultiply", "[", 
    RowBox[{"A", ",", " ", "B"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"result", "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", " ", "1"}], "]"}], "]"}], " ", "===", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "[", 
     RowBox[{"1", ",", " ", "1"}], "]"}], " ", "**", " ", 
    RowBox[{"ad", "[", 
     RowBox[{"1", ",", " ", "1"}], "]"}]}], " ", "+", " ", 
   RowBox[{
    RowBox[{"a", "[", 
     RowBox[{"1", ",", " ", "2"}], "]"}], " ", "**", " ", 
    RowBox[{"ad", "[", 
     RowBox[{"2", ",", " ", "1"}], "]"}]}]}]}]}], "VerificationTest",
 CellChangeTimes->{{3.9724487037504168`*^9, 3.972448708734478*^9}},
 CellLabel->"In[37]:=",
 CellID->327180814,ExpressionUUID->"fbcd8882-8fc0-4585-9634-ad007559a222"],

