Cell[BoxData[
 RowBox[{"TestOperatorEqualityExplicit", "[", "\n", "    ", 
  RowBox[{
   RowBox[{
    RowBox[{"2", " ", "*", " ", 
     RowBox[{
      RowBox[{"ad", "[", 
       RowBox[{"1", ",", " ", "2"}], "]"}], " ", "**", " ", 
      RowBox[{"a", "[", 
       RowBox[{"3", ",", " ", "4"}], "]"}]}]}], " ", "+", " ", 
    RowBox[{"3", " ", "*", " ", 
     RowBox[{
      RowBox[{"ad", "[", 
       RowBox[{"5", ",", " ", "6"}], "]"}], " ", "**", " ", 
      RowBox[{"a", "[", 
       RowBox[{"7", ",", " ", "8"}], "]"}]}]}]}], ",", "\n", "    ", 
   RowBox[{
    RowBox[{"2", " ", "*", " ", 
