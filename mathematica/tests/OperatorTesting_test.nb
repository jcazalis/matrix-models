Cell[CellGroupData[{

Cell["Section 8: Advanced Identity Tests", "Section",
 CellID->1861456637,ExpressionUUID->"872f3c99-68ef-426e-a143-ff09d28d0680"],

Cell[CellGroupData[{

Cell["Test Complex Operator Identities", "Subsection",
 CellID->959928563,ExpressionUUID->"bc2e08dc-1589-469e-aac4-2edfeb213d59"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TestOperatorEqualityExplicit", "[", "\n", "    ", 
  RowBox[{
   RowBox[{
    RowBox[{"ad", "[", 
     RowBox[{"1", ",", " ", "2"}], "]"}], " ", "**", " ", 
    RowBox[{"a", "[", 
     RowBox[{"2", ",", " ", "3"}], "]"}], " ", "**", " ", 
    RowBox[{"ad", "[", 
     RowBox[{"3", ",", " ", "1"}], "]"}]}], ",", "\n", "    ", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", 
      RowBox[{"2", ",", " ", "3"}], "]"}], " ", "**", " ", 
     RowBox[{"ad", "[", 
      RowBox[{"1", ",", " ", "2"}], "]"}], " ", "**", " ", 
     RowBox[{"ad", "[", 
      RowBox[{"3", ",", " ", "1"}], "]"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"ad", "[", 
      RowBox[{"3", ",", " ", "1"}], "]"}], " ", "*", " ", 
     RowBox[{"\[Delta]", "[", 
      RowBox[{"1", ",", " ", "2"}], "]"}], " ", "*", " ", 
     RowBox[{"\[Delta]", "[", 
      RowBox[{"2", ",", " ", "3"}], "]"}]}]}]}], "\n", "  ", 
  "]"}]], "VerificationTest",
 CellChangeTimes->{
  3.972448685644042*^9, {3.9724520939942555`*^9, 3.972452095741552*^9}},
 CellLabel->"In[34]:=",
 CellID->1622202077,ExpressionUUID->"d2843700-0b92-44ab-823a-0046e83d6231"],

