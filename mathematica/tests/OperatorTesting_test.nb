Cell[BoxData[{
 RowBox[{
  RowBox[{"M", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"1", ",", " ", "1"}], "]"}], ",", " ", 
       RowBox[{"a", "[", 
        RowBox[{"1", ",", " ", "2"}], "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"2", ",", " ", "1"}], "]"}], ",", " ", 
       RowBox[{"a", "[", 
        RowBox[{"2", ",", " ", "2"}], "]"}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trace", " ", "=", " ", 
   RowBox[{"NCTr", "[", "M", "]"}]}], ";"}], "\n", 
 RowBox[{"trace", " ", "===", " ", 
  RowBox[{
   RowBox[{"a", "[", 
    RowBox[{"1", ",", " ", "1"}], "]"}], " ", "+", " ", 
   RowBox[{"a", "[", 
    RowBox[{"2", ",", " ", "2"}], "]"}]}]}]}], "VerificationTest",
