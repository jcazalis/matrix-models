Cell[CellGroupData[{

Cell["Test ExpandImplicitIndices - With NonCommutativeMultiply", "Subsection",
 CellID->1453615100,ExpressionUUID->"12cd3523-e495-44ec-8789-40f53e94e4a2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"expr", " ", "=", " ", 
   RowBox[{
    RowBox[{"ad", "[", 
     RowBox[{"k1", ",", " ", "k2"}], "]"}], " ", "**", " ", 
    RowBox[{"a", "[", 
     RowBox[{"k2", ",", " ", "k1"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"expanded", " ", "=", " ", 
   RowBox[{"ExpandImplicitIndices", "[", 
    RowBox[{"expr", ",", " ", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"expected", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"ad", "[", 
      RowBox[{"1", ",", " ", "1"}], "]"}], " ", "**", " ", 
     RowBox[{"a", "[", 
      RowBox[{"1", ",", " ", "1"}], "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"ad", "[", 
      RowBox[{"1", ",", " ", "2"}], "]"}], " ", "**", " ", 
     RowBox[{"a", "[", 
      RowBox[{"2", ",", " ", "1"}], "]"}]}], " ", "+", " ", "\n", 
    RowBox[{
     RowBox[{"ad", "[", 
      RowBox[{"2", ",", " ", "1"}], "]"}], " ", "**", " ", 
     RowBox[{"a", "[", 
      RowBox[{"1", ",", " ", "2"}], "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"ad", "[", 
      RowBox[{"2", ",", " ", "2"}], "]"}], " ", "**", " ", 
     RowBox[{"a", "[", 
      RowBox[{"2", ",", " ", "2"}], "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Simplify", "[", 
   RowBox[{"expanded", " ", "-", " ", "expected"}], "]"}], " ", "===", " ", 
  "0"}]}], "VerificationTest",
 CellChangeTimes->{{3.972448265178925*^9, 3.972448273437355*^9}},
 CellLabel->"In[17]:=",
 CellID->1686437883,ExpressionUUID->"87c242ec-6fa2-4c18-8544-91803ae7190e"],

