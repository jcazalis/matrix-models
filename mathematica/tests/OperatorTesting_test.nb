Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"expr", " ", "=", " ", 
   RowBox[{"a", "[", 
    RowBox[{"k1", ",", " ", "k2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"expanded", " ", "=", " ", 
   RowBox[{"ExpandImplicitIndices", "[", 
    RowBox[{"expr", ",", " ", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"expected", " ", "=", " ", 
   RowBox[{
    RowBox[{"a", "[", 
     RowBox[{"1", ",", " ", "1"}], "]"}], " ", "+", " ", 
    RowBox[{"a", "[", 
     RowBox[{"1", ",", " ", "2"}], "]"}], " ", "+", " ", 
    RowBox[{"a", "[", 
     RowBox[{"2", ",", " ", "1"}], "]"}], " ", "+", " ", 
    RowBox[{"a", "[", 
     RowBox[{"2", ",", " ", "2"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Simplify", "[", 
   RowBox[{"expanded", " ", "-", " ", "expected"}], "]"}], " ", "==", " ", 
  "0"}]}], "VerificationTest",
 CellChangeTimes->{{3.972448173705682*^9, 3.972448183829109*^9}},
 CellLabel->"In[15]:=",
 CellID->1122694836,ExpressionUUID->"77c269a7-1ce3-4c1a-85e0-f9e061f04977"],

