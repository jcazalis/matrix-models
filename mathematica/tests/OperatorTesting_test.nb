Cell[BoxData[
 RowBox[{"TestOperatorEqualityImplicit", "[", "\n", "    ", 
  RowBox[{
   RowBox[{
    RowBox[{"ad", "[", 
     RowBox[{"k1", ",", " ", "k2"}], "]"}], " ", "**", " ", 
    RowBox[{"a", "[", 
     RowBox[{"k2", ",", " ", "k1"}], "]"}]}], ",", "\n", "    ", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", 
      RowBox[{"k2", ",", " ", "k1"}], "]"}], " ", "**", " ", 
     RowBox[{"ad", "[", 
      RowBox[{"k1", ",", " ", "k2"}], "]"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"\[Delta]", "[", 
      RowBox[{"k1", ",", " ", "k1"}], "]"}], " ", "*", " ", 
     RowBox[{"\[Delta]", "[", 
      RowBox[{"k2", ",", " ", "k2"}], "]"}]}]}], ",", "\n", "    ", "3"}], 
  "\n", "  ", "]"}]], "VerificationTest",
 CellChangeTimes->{
  3.972448461954969*^9, {3.972452074925278*^9, 3.972452077368663*^9}},
 CellLabel->"In[25]:=",
 CellID->305617067,ExpressionUUID->"3b8534c6-e029-4e21-96bd-78ad6b57aaad"],

